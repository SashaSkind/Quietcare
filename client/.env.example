# Quietcare client environment variables.
# Copy this file to `.env` and fill in values. NO SECRETS belong in the client.

# WebSocket endpoint for the backend (include the /ws path).
# For the bundled mock backend, use your machine's LAN IP so a physical device can reach it,
# e.g. ws://192.168.1.50:8080/ws  (use ws://localhost:8080/ws only for an emulator on the same host).
EXPO_PUBLIC_WS_URL=ws://localhost:8080/ws

# Sentry DSN for the CLIENT project. A DSN is NOT a secret (it only permits sending events),
# so committing the real value here is fine.
EXPO_PUBLIC_SENTRY_DSN=https://a0cb3c3cd9fa95ac05f1f745a694fbdd@o4511600571777024.ingest.us.sentry.io/4511600856924160

# Elder identifier this device represents.
EXPO_PUBLIC_ELDER_ID=margaret-01

# REST base URL of the backend (used by the in-app caretaker dashboard and the
# on-device demo incident reporting). Use your machine's LAN IP for a physical
# device, e.g. http://192.168.1.50:8080 (localhost only works in a simulator).
EXPO_PUBLIC_API_URL=http://localhost:8080
