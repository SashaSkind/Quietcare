# Base URL of the Quietcare FastAPI backend.
# In dev, leave this as /api to use the Vite proxy (see vite.config.ts), which
# forwards to VITE_API_TARGET (default http://localhost:8000) and avoids CORS.
# In production, set this to the deployed backend origin, e.g. https://api.quietcare.app
VITE_API_BASE=/api

# Where the dev proxy forwards /api -> (only used by `npm run dev`).
VITE_API_TARGET=http://localhost:8000
