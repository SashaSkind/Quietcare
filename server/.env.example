# Quietcare backend configuration.
# Copy to .env and fill in. EVERY key is optional: when a key is absent the
# corresponding provider automatically falls back to an in-memory/mock impl so
# the whole system runs locally with zero credentials.

# ---- LLM (Anthropic Messages API) ----
# When unset, a deterministic mock LLM drives the agents.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- LLM via PaleBlueDot TokenRouter (preferred when set) ----
# Anthropic-compatible gateway that serves Claude with free credits. When both
# values are set, the LLM is routed through PBD and falls back to the direct
# Anthropic key above if PBD init fails. BASE_URL is the PBD endpoint the
# Anthropic SDK appends /v1/messages to (e.g. https://router.palebluedot.ai).
PALEBLUEDOT_API_KEY=
PALEBLUEDOT_BASE_URL=

# ---- Voice (Deepgram STT/TTS) ----
# When unset, mock STT returns canned text and mock TTS returns silence.
DEEPGRAM_API_KEY=

# ---- Audio-scene ML (YAMNet distress detection) ----
# Non-speech distress tagging (thud/scream/groan/glass) on phone audio, fused
# into the elder-agent's decision. Point both at a local YAMNet .tflite model
# and its class-map CSV. When unset, a deterministic mock derives tags from
# scenario hints. Requires the optional `numpy` + a TFLite runtime
# (`ai-edge-litert` or `tflite-runtime`).
YAMNET_MODEL_PATH=
YAMNET_LABELS_PATH=
# Backend selector: auto | yamnet | panns | both | mock. "both" runs YAMNet +
# PANNs as an ensemble (distress = OR). PANNs (CNN14) is heavier — needs
# `pip install panns-inference torch` and a ~300MB checkpoint (auto-downloads,
# or set PANNS_CHECKPOINT_PATH).
AUDIO_SCENE_BACKEND=auto
PANNS_CHECKPOINT_PATH=

# ---- Memory (Redis) ----
# When unset, an in-memory dict is used (seeded with a sample elder profile).
REDIS_URL=

# ---- Telephony (Twilio) ----
# When any of these is unset, telephony is mocked (logs "WOULD SEND/CALL ...").
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_CARETAKER_NUMBER=

# ---- Message bus (BAND) ----
# When BAND_API_KEY + BAND_REST_URL are unset, an in-process async queue is used
# (default). BAND_REST_URL is used for publish; BAND_WS_URL for streaming
# subscriptions; BAND_BASE_URL is an app/project id kept for future use.
BAND_API_KEY=
BAND_BASE_URL=
BAND_REST_URL=
BAND_WS_URL=

# ---- Emergency dispatch (gated 911 path) ----
# Used ONLY after explicit human confirmation via POST /incidents/{id}/confirm_911.
# NEVER set this to a real PSAP/911 line in a demo — use a safe test number you
# control. When unset, emergency dispatch is logged only (mocked).
EMERGENCY_NUMBER=

# ---- Browser automation (Browserbase) ----
# Everyday-care computer-use path (e.g. prescription refill on a pharmacy
# portal), reachable via the caretaker-agent's refill_medication tool or
# POST /elders/{id}/refill. When unset, a mock logs the intended task. Always
# runs OFF the emergency critical path.
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# ---- ArmorIQ MCP security scanner ----
# ArmorIQ scans MCP server endpoints for vulnerabilities (SAFE-MCP techniques)
# and returns a vulnerability_score + severity_level via POST {BASE_URL}/scan.
# Used as a security-posture check (NOT an inline action gate). Trigger via
# POST /admin/security-scan {"url": ...}; ARMORIQ_SCAN_TARGETS (comma-separated
# MCP endpoint URLs) are scanned at startup and logged. When unset, a mock
# returns a "safe" report.
ARMORIQ_API_KEY=
ARMORIQ_BASE_URL=https://api.armoriq.ai
ARMORIQ_SCAN_TARGETS=

# ---- Local policy gate (escalation chokepoint) ----
# In-code gate that can physically block high-stakes escalation actions
# ('escalation', 'emergency_dispatch') before they fire — independent of the
# LLM. Computes a 0-100 risk score from context. Allows by default;
# POLICY_BLOCK_ACTIONS is a comma-separated kill-switch. EMERGENCY_MIN_RISK
# blocks an emergency_dispatch below that score unless a human already confirmed.
POLICY_BLOCK_ACTIONS=
EMERGENCY_MIN_RISK=0

# ---- Medication reminders ----
# Scheduled spoken reminders + adherence logging. Set a schedule per elder via
# PUT /elders/{id}/medications. The scheduler ticks every MED_TICK_SECONDS and
# waits MED_CONFIRM_WINDOW_MS for a spoken "yes/no" before logging a missed dose.
MED_TICK_SECONDS=60
MED_CONFIRM_WINDOW_MS=8000

# ---- Geofence / wandering ----
# Local 24h night window; leaving the safe zone during these hours is treated as
# higher severity. The client supplies the geofence + location signal.
NIGHT_START_HOUR=22
NIGHT_END_HOUR=6

# ---- Inbound caretaker SMS ----
# Point your Twilio number's "A MESSAGE COMES IN" webhook (POST) at
#   https://<your-host>/twilio/sms
# A caretaker can then text the number ("how's mom today?") and get a recap.
# The sender's number is matched to an elder via that elder's caretaker.phone.

# ---- Arize AX observability (optional) ----
# Traces the agent tool-use loop and Claude calls to Arize via OpenTelemetry
# (arize-otel) + OpenInference auto-instrumentation. When SPACE_ID + API_KEY are
# set, tracing is enabled; otherwise it's a no-op. ARIZE_PROJECT_NAME groups
# traces in the Arize UI. Requires:  pip install arize-otel
# openinference-instrumentation-anthropic
ARIZE_SPACE_ID=
ARIZE_API_KEY=
ARIZE_PROJECT_NAME=quietcare

# ---- Sentry (optional) ----
SENTRY_DSN=

# ---- Server ----
HOST=0.0.0.0
PORT=8080

# ---- Auth (multi-elder / per-device identity) ----
# When true, WS register/trigger must carry a valid device_token (provision an
# elder + token via POST /elders). Default false keeps the zero-config demo.
REQUIRE_DEVICE_AUTH=false
# Optional shared token guarding POST /elders (sent as X-Admin-Token header).
# When unset, provisioning is open (local/demo only).
ADMIN_TOKEN=
